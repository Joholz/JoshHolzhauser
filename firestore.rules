rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /leads/{leadId} {
      // Anyone can submit a lead (contact form)
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'projectType', 'message', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.email is string
                    && request.resource.data.message is string
                    && request.resource.data.name.size() <= 100
                    && request.resource.data.email.size() <= 200
                    && request.resource.data.message.size() <= 3000;

      // Only Josh can read and update leads
      allow read, update: if request.auth != null
                          && request.auth.token.email == 'wunkoteam@gmail.com';
    }
  }
}
